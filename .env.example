# local-sqlite | local-postgres | test | render-postgres
APP_PROFILE=local-sqlite
NODE_ENV=development
HOST=127.0.0.1
PORT=3000
BASE_URL=http://localhost:3000
SQLITE_PATH=./data/quick-interview.sqlite
# DATABASE_URL=postgresql://quick_interview:change-me@localhost:5432/quick_interview
# Optional PostgreSQL-only URL used by `npm run migrate` (use a direct Neon URL).
# MIGRATION_DATABASE_URL=postgresql://quick_interview:change-me@localhost:5432/quick_interview
LOG_LEVEL=info
SESSION_TTL_MINUTES=480
CANDIDATE_TOKEN_TTL_MINUTES=10080
RUNNER_TOKEN_TTL_MINUTES=15
RUNNER_CREDENTIAL_TTL_MINUTES=180
LOGIN_WINDOW_MINUTES=15
LOGIN_MAX_FAILURES=5
HEARTBEAT_OFFLINE_SECONDS=90
DATA_RETENTION_DAYS=365

# Optional AI Assistant for admin question generation.
# OPEN_API_URL is supported for compatibility; OPENAI_API_URL is preferred.
# OPEN_API_URL=https://ollama.com/v1
# OPENAI_API_URL=https://ollama.com/v1
# OPENAI_API_KEY=replace-with-provider-key
# OPENAI_MODEL=gpt-oss:120b

# Used only by `npm run bootstrap-admin`; remove after bootstrapping.
# BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# BOOTSTRAP_ADMIN_PASSWORD=use-a-long-unique-password

# Used only by `npm run seed:question-bank`; remove after seeding.
# SEED_ADMIN_EMAIL=admin@example.com
